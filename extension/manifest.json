{
  "manifest_version": 3,
  "name": "Swoosh",
  "version": "2.1",
  "minimum_chrome_version": "120",
  "description": "Your tabs, organized. Swoosh groups open tabs by site, surfaces stale ones, and clears clutter — with a satisfying swoosh.",
  "permissions": ["tabs", "storage", "bookmarks"],
  "host_permissions": ["https://suggestqueries.google.com/*"],
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Swoosh",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
